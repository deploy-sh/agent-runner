# agent-runner configuration
# Copy to ~/.agent-runner/.env or .env in your project directory
# Local .env takes priority over ~/.agent-runner/.env

# ─── Required ─────────────────────────────────────────────────────────────────

AGENT_API_KEY=your-api-key-here

# ─── Provider / Model ─────────────────────────────────────────────────────────

# OpenRouter (recommended — 200+ models, free tier available)
AGENT_BASEURL=https://openrouter.ai/api/v1
AGENT_MODEL=google/gemini-2.0-flash-001

# Groq (fast inference, free tier)
#AGENT_BASEURL=https://api.groq.com/openai/v1
#AGENT_MODEL=llama-3.3-70b-versatile

# Mistral AI (EU-based, strong at code)
#AGENT_BASEURL=https://api.mistral.ai/v1
#AGENT_MODEL=mistral-large-latest

# OpenAI
#AGENT_BASEURL=https://api.openai.com/v1
#AGENT_MODEL=gpt-4o-mini

# Ollama (local, no API key needed)
#AGENT_BASEURL=http://localhost:11434/v1
#AGENT_API_KEY=ollama
#AGENT_MODEL=qwen2.5-coder:7b

# ─── Optional ─────────────────────────────────────────────────────────────────

# Max tool-call iterations per turn (default: 15)
#AGENT_MAX_ITER=15

# System prompt override (inline text)
#AGENT_SYSTEM=You are a Linux sysadmin expert. Be concise.

# System prompt from file (e.g. project CLAUDE.md)
#AGENT_SYSTEM_FILE=/path/to/CLAUDE.md

# MCP server SSE URL (adds extra tools)
#AGENT_MCP_URL=https://mcp.example.com/sse

# Context window size for auto-compression (default: 32000)
# Use 128000 for large-context models (Gemini, Qwen3, etc.)
#AGENT_CONTEXT_TOKENS=128000

# Enable fallback mode for models without native tool_calls
#AGENT_FALLBACK=false

# ─── Provider-specific keys (used by /source menu in REPL) ────────────────────
# These are checked by the /source command when switching providers interactively.
# Not required if you set AGENT_API_KEY directly above.

#OPENROUTER_API_KEY=sk-or-v1-...
#GROQ_API_KEY=gsk_...
#MISTRAL_API_KEY=...
#OPENAI_API_KEY=sk-...
